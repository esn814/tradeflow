# TradeFlow Server — Environment Variables
# Copy to .env and fill in values

# REQUIRED: JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# Server port (default: 3001)
PORT=3001

# Node environment (development|production)
NODE_ENV=development

# Database path (default: ./data/tradeflow.db)
DB_PATH=

# SIWE domain for signature verification
SIWE_DOMAIN=tradeflow.cloud.hyperpaxeer.com

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://tradeflow.cloud.hyperpaxeer.com

# Backup retention in days (default: 7)
BACKUP_RETENTION_DAYS=7

# Log level (fatal|error|warn|info|debug|trace|silent)
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# VAPID keys for web push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
