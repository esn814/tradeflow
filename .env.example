# ── Server ──────────────────────────────────────────────────────
# Required: JWT secret for signing tokens (generate with: openssl rand -hex 32)
JWT_SECRET=

# CORS origins (comma-separated). Defaults to localhost:5173 + prod domain
# CORS_ORIGINS=https://tradeflow.cloud.hyperpaxeer.com,https://tradeflow-staging.cloud.hyperpaxeer.com

# SQLite database path. On Render, use the persistent disk mount.
# DB_PATH=/app/data/tradeflow.db

# Server port
# PORT=3001

# Node environment
# NODE_ENV=production

# SIWE domain for signature verification (must match frontend domain)
# SIWE_DOMAIN=tradeflow.cloud.hyperpaxeer.com

# Backup retention in days (default: 7)
# BACKUP_RETENTION_DAYS=7

# ── Frontend (Vite) ─────────────────────────────────────────────
# Backend API URL
# VITE_API_URL=https://tradeflow-api-i2o1.onrender.com/api

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=
